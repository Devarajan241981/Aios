#!/usr/bin/env python3
"""aios — command-line client for the AIOS AI-core daemon (aiosd).

Usage:
    aios ask "how do I free up disk space?"
    echo "summarise this" | aios ask
    aios chat
    aios status
    aios index ~/Documents ~/notes      # build semantic memory over your files
    aios index --stats
    aios search "where did I discuss the budget?"
"""

from __future__ import annotations

import argparse
import json
import os
import sys
import urllib.error
import urllib.request

HOST = os.environ.get("AIOS_HOST", "127.0.0.1")
PORT = os.environ.get("AIOS_PORT", "8765")


def base_url() -> str:
    return f"http://{HOST}:{PORT}"


def _headers() -> dict:
    headers = {"Content-Type": "application/json"}
    token = os.environ.get("AIOS_TOKEN")
    if token:
        headers["Authorization"] = f"Bearer {token}"
    return headers


def request(method: str, path: str, payload=None, timeout: float = 125.0):
    data = json.dumps(payload).encode() if payload is not None else None
    req = urllib.request.Request(
        base_url() + path,
        data=data,
        method=method,
        headers=_headers(),
    )
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            return resp.status, json.loads(resp.read().decode())
    except urllib.error.HTTPError as exc:
        try:
            return exc.code, json.loads(exc.read().decode())
        except Exception:
            return exc.code, {"error": f"HTTP {exc.code}"}
    except urllib.error.URLError as exc:
        return None, {
            "error": (
                f"cannot reach aiosd at {base_url()}: {exc.reason}. "
                "Start it with `make run` (or `python -m aiosd` in ai-core/)."
            )
        }


def stream_request(path: str, payload, timeout: float = 600.0):
    """POST with stream=true and yield parsed SSE event dicts."""
    data = json.dumps({**payload, "stream": True}).encode()
    req = urllib.request.Request(
        base_url() + path, data=data, method="POST", headers=_headers(),
    )
    resp = urllib.request.urlopen(req, timeout=timeout)
    for raw in resp:
        line = raw.decode("utf-8", errors="replace").rstrip("\r\n")
        if not line.startswith("data:"):
            continue
        body = line[len("data:"):].strip()
        if body == "[DONE]":
            break
        try:
            yield json.loads(body)
        except ValueError:
            continue


def cmd_index(args) -> int:
    if args.stats:
        code, body = request("GET", "/v1/index/stats", timeout=8)
        if code is None or code >= 400:
            print(body.get("error", "error"), file=sys.stderr)
            return 1
        print(f"documents: {body['documents']}")
        for source in body["sources"]:
            print(f"  {source}")
        return 0

    if not args.paths:
        print("give one or more files/folders to index (or --stats)", file=sys.stderr)
        return 2
    paths = [os.path.abspath(os.path.expanduser(p)) for p in args.paths]
    print(f"indexing {len(paths)} path(s)… (this reads your files locally; nothing is uploaded)")
    code, body = request("POST", "/v1/index", {"paths": paths}, timeout=600)
    if code is None or code >= 400:
        print(body.get("error", "error"), file=sys.stderr)
        return 1
    print(f"indexed {body['indexed']} new chunk(s); {body['documents']} total in memory")
    return 0


def cmd_search(args) -> int:
    query = " ".join(args.query).strip()
    if not query:
        print("nothing to search for", file=sys.stderr)
        return 2
    code, body = request("POST", "/v1/search", {"query": query, "k": args.k})
    if code is None or code >= 400:
        print(body.get("error", "error"), file=sys.stderr)
        return 1
    results = body["results"]
    if not results:
        print("no matches (have you run `aios index <path>` yet?)")
        return 0
    for hit in results:
        snippet = " ".join(hit["text"].split())[:160]
        print(f"[{hit['score']:.3f}] {hit['source']}\n    {snippet}\n")
    return 0


def cmd_status(_args) -> int:
    code, body = request("GET", "/health", timeout=8)
    if code is None:
        print(body["error"], file=sys.stderr)
        return 1
    print(json.dumps(body, indent=2))
    return 0 if body.get("status") == "ok" else 1


def _print_preview(preview: str) -> None:
    """Print an action preview, coloring unified-diff lines when on a TTY."""
    color = sys.stdout.isatty()
    green, red, cyan, reset = "\033[32m", "\033[31m", "\033[36m", "\033[0m"
    for line in preview.splitlines():
        c = ""
        if color:
            if line.startswith("+") and not line.startswith("+++"):
                c = green
            elif line.startswith("-") and not line.startswith("---"):
                c = red
            elif line.startswith("@@"):
                c = cyan
        print(f"      {c}{line}{reset}" if c else f"      {line}")


def _stream_prompt(prompt: str, session=None, history=None) -> str:
    """Stream a reply to stdout as it arrives; return the full text."""
    payload = {"prompt": prompt}
    if session:
        payload["session_id"] = session
    elif history is not None:
        payload["history"] = history
    parts: list[str] = []
    try:
        for evt in stream_request("/v1/chat", payload):
            if "delta" in evt:
                sys.stdout.write(evt["delta"])
                sys.stdout.flush()
                parts.append(evt["delta"])
            elif "error" in evt:
                sys.stderr.write("\n" + evt["error"] + "\n")
    except urllib.error.URLError as exc:
        sys.stderr.write(f"\ncannot reach aiosd at {base_url()}: {exc.reason}\n")
    return "".join(parts)


def _ask_with_tools(prompt: str, auto_approve: bool, session=None) -> int:
    approved: list[str] = []
    for _round in range(8):
        payload = {"prompt": prompt, "use_tools": True, "approve": auto_approve}
        if session:
            payload["session_id"] = session
        if approved:
            payload["approved_signatures"] = approved
        code, body = request("POST", "/v1/chat", payload, timeout=600)
        if code is None or code >= 400:
            print(body.get("error", "error"), file=sys.stderr)
            return 1

        if body.get("status") == "needs_approval":
            print("\nThe assistant wants to run the following action(s):\n")
            for p in body["pending"]:
                print(f"  ▸ {p['tool']}")
                _print_preview(p["preview"])
                print()
            try:
                answer = input(f"Approve these {len(body['pending'])} action(s)? [y/N] ").strip().lower()
            except EOFError:
                answer = ""
            if answer in ("y", "yes"):
                approved.extend(p["signature"] for p in body["pending"])
                continue
            print("declined — nothing was changed.")
            return 0

        print(body["reply"])
        if body.get("steps"):
            _print_steps(body["steps"])
        return 0

    print("too many approval rounds; aborting.", file=sys.stderr)
    return 1


def _print_steps(steps) -> None:
    for step in steps:
        result = step["result"]
        if result.get("ok"):
            status = "ok"
        elif result.get("needs_approval"):
            status = "needs approval"
        else:
            status = f"error: {result.get('error')}"
        args = ", ".join(f"{k}={v!r}" for k, v in (step.get("args") or {}).items())
        print(f"  · {step['tool']}({args}) → {status}", file=sys.stderr)


def cmd_ask(args) -> int:
    prompt = " ".join(args.prompt).strip()
    if not prompt and not sys.stdin.isatty():
        prompt = sys.stdin.read().strip()
    if not prompt:
        print("nothing to ask (pass a question or pipe text via stdin)", file=sys.stderr)
        return 2

    if args.tools:
        return _ask_with_tools(prompt, auto_approve=args.approve)

    try:
        printed = False
        for evt in stream_request("/v1/chat", {"prompt": prompt}):
            if "delta" in evt:
                sys.stdout.write(evt["delta"])
                sys.stdout.flush()
                printed = True
            elif "error" in evt:
                if printed:
                    print()
                print(evt["error"], file=sys.stderr)
                return 1
        if printed:
            print()
        return 0
    except urllib.error.URLError as exc:
        print(
            f"cannot reach aiosd at {base_url()}: {exc.reason}. "
            "Start it with `make run` (or `python -m aiosd` in ai-core/).",
            file=sys.stderr,
        )
        return 1


def cmd_chat(args) -> int:
    session = getattr(args, "session", None)
    banner = "AIOS chat" + (f" [session: {session}]" if session else "")
    print(banner + " — type 'exit' or Ctrl-D to quit")
    history: list[dict] = []
    while True:
        try:
            line = input("you› ").strip()
        except EOFError:
            print()
            break
        if line in ("exit", "quit"):
            break
        if not line:
            continue
        sys.stdout.write("aios› ")
        sys.stdout.flush()
        parts: list[str] = []
        error = None
        # With a session the daemon persists and replays history from its DB;
        # otherwise we carry it in-process for this run only.
        payload = {"prompt": line}
        if session:
            payload["session_id"] = session
        else:
            payload["history"] = history
        try:
            for evt in stream_request("/v1/chat", payload):
                if "delta" in evt:
                    sys.stdout.write(evt["delta"])
                    sys.stdout.flush()
                    parts.append(evt["delta"])
                elif "error" in evt:
                    error = evt["error"]
                    break
        except urllib.error.URLError as exc:
            print()
            print(f"cannot reach aiosd at {base_url()}: {exc.reason}", file=sys.stderr)
            continue
        print("\n")  # end the reply line + a blank spacer
        if error:
            print(error, file=sys.stderr)
            continue
        history.append({"role": "user", "content": line})
        history.append({"role": "assistant", "content": "".join(parts)})
    return 0


def cmd_overlay(args) -> int:
    """Compact assistant loop, purpose-built for the desktop overlay window."""
    session = args.session or "overlay"
    dim, mag, cyan, reset = "\033[2m", "\033[1;35m", "\033[36m", "\033[0m"
    sys.stdout.write(f"{dim}AIOS · ask anything · prefix '!' to use tools · Ctrl-D to hide{reset}\n")
    while True:
        try:
            line = input(f"{mag}› {reset}").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            return 0
        if line in ("exit", "quit"):
            return 0
        if not line:
            continue
        use_tools = args.tools or line.startswith("!")
        if line.startswith("!"):
            line = line[1:].strip()
        if not line:
            continue
        if use_tools:
            _ask_with_tools(line, auto_approve=args.approve, session=session)
        else:
            sys.stdout.write(cyan)
            _stream_prompt(line, session=session)
            sys.stdout.write(reset + "\n\n")
    return 0


def _fmt_time(ts) -> str:
    import datetime
    return datetime.datetime.fromtimestamp(ts).strftime("%Y-%m-%d %H:%M")


def cmd_sessions(_args) -> int:
    code, body = request("GET", "/v1/sessions", timeout=8)
    if code is None or code >= 400:
        print(body.get("error", "error"), file=sys.stderr)
        return 1
    sessions = body["sessions"]
    if not sessions:
        print("no sessions yet — start one with `aios chat --session <name>`")
        return 0
    for s in sessions:
        print(f"{s['id']:<14} {s['messages']:>3} msgs  {_fmt_time(s['updated_at'])}  {s['title']}")
    return 0


def cmd_history(args) -> int:
    code, body = request("GET", f"/v1/sessions/{args.session}", timeout=8)
    if code is None or code >= 400:
        print(body.get("error", "error"), file=sys.stderr)
        return 1
    for m in body["messages"]:
        who = "you" if m["role"] == "user" else "aios"
        print(f"{who}› {m['content']}")
    return 0


def cmd_config(_args) -> int:
    base = os.environ.get("XDG_CONFIG_HOME") or os.path.join(os.path.expanduser("~"), ".config")
    path = os.environ.get("AIOS_CONFIG") or os.path.join(base, "aios", "config.toml")
    exists = os.path.exists(path)
    print(f"config file: {path}")
    print(f"             {'found' if exists else 'not present (using defaults + environment)'}")
    print("precedence:  defaults < config file < environment variables\n")
    code, body = request("GET", "/config", timeout=8)
    if code is None or code >= 400:
        print("(start the daemon with `make run` to see effective settings)", file=sys.stderr)
        return 0 if code is None else 1
    print("effective settings (from the running daemon):")
    for key in sorted(body):
        print(f"  {key} = {body[key]}")
    return 0


def _load_scheduler():
    here = os.path.dirname(os.path.realpath(__file__))
    core = os.path.join(os.path.dirname(here), "ai-core")
    if os.path.isdir(core) and core not in sys.path:
        sys.path.insert(0, core)
    from aiosd.schedule import Scheduler  # noqa: E402
    from aiosd.platform.services import current_service_manager  # noqa: E402
    cfg_base = os.environ.get("XDG_CONFIG_HOME") or os.path.join(os.path.expanduser("~"), ".config")
    data_base = os.environ.get("XDG_DATA_HOME") or os.path.join(os.path.expanduser("~"), ".local", "share")
    svc = current_service_manager(unit_dir=os.path.join(cfg_base, "systemd", "user"))
    return Scheduler(
        service_manager=svc,
        data_dir=os.path.join(data_base, "aios"),
        aios_bin=os.path.realpath(__file__),
    )


def cmd_schedule_add(args) -> int:
    sched = _load_scheduler()  # also puts aiosd on sys.path
    from aiosd.schedule import ScheduleError
    try:
        rec = sched.add(args.name, args.at, args.prompt)
    except ScheduleError as exc:
        print(exc, file=sys.stderr)
        return 2
    print(f"scheduled '{rec['name']}' — {rec['calendar']}  (backend: {rec['backend']})")
    print(f"  runs: aios ask \"{rec['prompt']}\"")
    print(f"  log:  {rec['log']}")
    if not sched.available:
        print("  (no systemd here — units written; enable them on a Linux system)")
    return 0


def cmd_schedule_list(_args) -> int:
    for rec in _load_scheduler().list():
        print(f"{rec['name']:<16} {rec['calendar']:<22} {rec['prompt']}")
    return 0


def cmd_schedule_remove(args) -> int:
    ok = _load_scheduler().remove(args.name)
    print(f"removed '{args.name}'" if ok else f"no such automation: {args.name}")
    return 0 if ok else 1


def cmd_session(args) -> int:
    here = os.path.dirname(os.path.realpath(__file__))
    core = os.path.join(os.path.dirname(here), "ai-core")
    if os.path.isdir(core) and core not in sys.path:
        sys.path.insert(0, core)
    from aiosd.session import make_session_manager
    sm = make_session_manager(greeter=args.greeter)
    print(f"# AIOS login session — launches: {sm.session_command()}")
    print("# Install greetd, then write the following to /etc/greetd/config.toml (root):\n")
    print(sm.greeter_config(autologin_user=args.autologin), end="")
    return 0


def _package_manager():
    here = os.path.dirname(os.path.realpath(__file__))
    core = os.path.join(os.path.dirname(here), "ai-core")
    if os.path.isdir(core) and core not in sys.path:
        sys.path.insert(0, core)
    from aiosd.packages import make_package_manager
    return make_package_manager()


def cmd_apps_list(_args) -> int:
    res = _package_manager().list_installed()
    if not res.get("ok"):
        print(res.get("error", "error"), file=sys.stderr)
        return 1
    apps = res["apps"]
    if not apps:
        print("no apps installed")
        return 0
    for a in apps:
        print(f"{a['id']:<40} {a.get('version', ''):<10} {a.get('name', '')}")
    return 0


def cmd_apps_search(args) -> int:
    res = _package_manager().search(" ".join(args.query))
    if not res.get("ok"):
        print(res.get("error", "error"), file=sys.stderr)
        return 1
    for r in res["results"]:
        print(f"{r['id']:<40} {r.get('name', '')} — {r.get('description', '')}")
    return 0


def cmd_apps_install(args) -> int:
    print(f"installing {args.app_id}… (this may download from {'flathub'})")
    res = _package_manager().install(args.app_id)
    print(f"installed {args.app_id}" if res.get("ok") else res.get("error", "error"),
          file=sys.stderr if not res.get("ok") else sys.stdout)
    return 0 if res.get("ok") else 1


def cmd_apps_remove(args) -> int:
    res = _package_manager().remove(args.app_id)
    print(f"removed {args.app_id}" if res.get("ok") else res.get("error", "error"),
          file=sys.stderr if not res.get("ok") else sys.stdout)
    return 0 if res.get("ok") else 1


def cmd_update(args) -> int:
    here = os.path.dirname(os.path.realpath(__file__))
    core = os.path.join(os.path.dirname(here), "ai-core")
    if os.path.isdir(core) and core not in sys.path:
        sys.path.insert(0, core)
    try:
        from aiosd.update import make_update_manager
    except Exception as exc:
        print(f"update unavailable: {exc}", file=sys.stderr)
        return 1
    mgr = make_update_manager(branch=args.branch)

    if args.apply:
        res = mgr.apply()
        if not res.get("ok"):
            print(res.get("error", "update failed"), file=sys.stderr)
            return 1
        if res.get("applied"):
            print(f"updated {res['from']} → {res['to']}")
            print("restart the daemon to apply:  systemctl --user restart aiosd  (or restart `make run`)")
            request("POST", "/v1/notifications",
                    {"title": "AIOS updated", "level": "success", "source": "update",
                     "body": f"{res['from']} → {res['to']} — restart to apply"}, timeout=5)
        else:
            print(res.get("message", "already up to date"))
        return 0

    st = mgr.status()
    if not st.get("ok"):
        print(st.get("error", "error"), file=sys.stderr)
        return 1
    print(f"AIOS {st['version']}  ({st['branch']} @ {st['current']})")
    if st["update_available"]:
        print(f"update available: {st['behind']} commit(s) behind ({st['latest']}) — apply with `aios update --apply`")
    else:
        print("up to date")
    if not st["clean"]:
        print("note: working tree has uncommitted changes (blocks --apply)")
    return 0


def cmd_doctor(_args) -> int:
    # The diagnostic logic lives in the aiosd package next to this script.
    here = os.path.dirname(os.path.realpath(__file__))
    core = os.path.join(os.path.dirname(here), "ai-core")
    if os.path.isdir(core) and core not in sys.path:
        sys.path.insert(0, core)
    try:
        from aiosd import doctor
    except Exception as exc:
        print(f"doctor unavailable (cannot import aiosd): {exc}", file=sys.stderr)
        return 1
    return doctor.run(base_url(), dict(os.environ), sys.stdout)


def cmd_audit(args) -> int:
    import datetime
    code, body = request("GET", f"/v1/audit?n={args.n}", timeout=8)
    if code is None or code >= 400:
        print(body.get("error", "error"), file=sys.stderr)
        return 1
    events = body["events"]
    if not events:
        print("no tool activity recorded yet")
        return 0
    for e in events:
        when = datetime.datetime.fromtimestamp(e.get("ts", 0)).strftime("%m-%d %H:%M:%S")
        if e.get("event") == "tool":
            status = "ok" if e.get("ok") else f"ERROR: {e.get('error')}"
            approved = " (approved)" if e.get("approved") else ""
            print(f"{when}  {e.get('tool')}{approved} → {status}")
        elif e.get("event") == "pending":
            print(f"{when}  {e.get('tool')} — awaited approval [{e.get('signature')}]")
        else:
            print(f"{when}  {e}")
    return 0


def cmd_grant(args) -> int:
    payload = {"tool": args.tool, "revoke": args.revoke}
    code, body = request("POST", f"/v1/sessions/{args.session}/grants", payload, timeout=8)
    if code is None or code >= 400:
        print(body.get("error", "error"), file=sys.stderr)
        return 1
    verb = "revoked" if args.revoke else "granted"
    grants = body.get("grants", [])
    print(f"{verb} '{args.tool}' for session {args.session}")
    print(f"session now auto-approves: {', '.join(grants) if grants else '(none)'}")
    return 0


def cmd_notify(args) -> int:
    title = " ".join(args.title).strip()
    if not title:
        print("a title is required", file=sys.stderr)
        return 2
    payload = {"title": title, "body": args.body or "", "level": args.level, "source": "cli"}
    code, body = request("POST", "/v1/notifications", payload, timeout=8)
    if code is None or code >= 400:
        print(body.get("error", "error"), file=sys.stderr)
        return 1
    print(f"notified: {body['title']}  [{body['level']}]")
    return 0


def cmd_notifications(args) -> int:
    import datetime
    if args.clear:
        code, body = request("DELETE", "/v1/notifications", timeout=8)
        print(f"cleared {body.get('cleared', 0)} notification(s)" if code == 200 else "error")
        return 0 if code == 200 else 1
    if args.read:
        code, body = request("POST", "/v1/notifications/read", {}, timeout=8)
        print(f"marked {body.get('read_all', 0)} as read" if code == 200 else "error")
        return 0 if code == 200 else 1
    path = f"/v1/notifications?n={args.n}" + ("&unread=1" if args.unread else "")
    code, body = request("GET", path, timeout=8)
    if code is None or code >= 400:
        print(body.get("error", "error"), file=sys.stderr)
        return 1
    items = body["notifications"]
    if not items:
        print("no notifications")
        return 0
    for n in items:
        when = datetime.datetime.fromtimestamp(n.get("ts", 0)).strftime("%m-%d %H:%M")
        mark = " " if n.get("read") else "•"
        line = f"{mark} {when}  [{n['level']}] {n['title']}"
        if n.get("body"):
            line += f" — {n['body']}"
        print(line)
    print(f"\n{body['unread']} unread", file=sys.stderr)
    return 0


def cmd_tools(_args) -> int:
    code, body = request("GET", "/v1/tools", timeout=8)
    if code is None or code >= 400:
        print(body.get("error", "error"), file=sys.stderr)
        return 1
    print(f"tools {'enabled' if body['enabled'] else 'disabled'}:")
    for t in body["tools"]:
        tag = "" if t["safe"] else "  (requires approval)"
        print(f"  {t['name']:<14} {t['description']}{tag}")
    return 0


def main(argv=None) -> int:
    parser = argparse.ArgumentParser(prog="aios", description="AIOS AI assistant client")
    sub = parser.add_subparsers(dest="cmd", required=True)

    ask = sub.add_parser("ask", help="ask a single question")
    ask.add_argument("prompt", nargs="*", help="the question (or pipe via stdin)")
    ask.add_argument("--tools", action="store_true", help="let the assistant use tools")
    ask.add_argument("--approve", action="store_true", help="approve mutating tools")
    ask.set_defaults(func=cmd_ask)

    chat = sub.add_parser("chat", help="interactive chat session")
    chat.add_argument("--session", help="named session; persists and resumes history")
    chat.set_defaults(func=cmd_chat)

    overlay = sub.add_parser("overlay", help="compact assistant loop for the desktop overlay")
    overlay.add_argument("--session", help="session id (default: 'overlay')")
    overlay.add_argument("--tools", action="store_true", help="use tools for every message")
    overlay.add_argument("--approve", action="store_true", help="auto-approve mutating tools")
    overlay.set_defaults(func=cmd_overlay)

    sub.add_parser("status", help="daemon + backend health").set_defaults(func=cmd_status)
    sub.add_parser("sessions", help="list saved chat sessions").set_defaults(func=cmd_sessions)
    sub.add_parser("tools", help="list available tools").set_defaults(func=cmd_tools)
    sub.add_parser("config", help="show config file + effective settings").set_defaults(func=cmd_config)
    sub.add_parser("doctor", help="diagnose the AIOS setup").set_defaults(func=cmd_doctor)

    update = sub.add_parser("update", help="check for / apply AIOS updates")
    update.add_argument("--apply", action="store_true", help="fast-forward to the latest")
    update.add_argument("--branch", default="main", help="branch to track (default main)")
    update.set_defaults(func=cmd_update)

    session = sub.add_parser("session", help="print the AIOS greetd login config")
    session.add_argument("--greeter", default="tuigreet", help="greeter binary (default tuigreet)")
    session.add_argument("--autologin", help="username to auto-login (single-user machine)")
    session.set_defaults(func=cmd_session)

    apps = sub.add_parser("apps", help="apps (Flatpak): list/search/install/remove")
    apps.set_defaults(func=cmd_apps_list)
    appssub = apps.add_subparsers(dest="appscmd")
    asearch = appssub.add_parser("search", help="search for apps")
    asearch.add_argument("query", nargs="+")
    asearch.set_defaults(func=cmd_apps_search)
    ainstall = appssub.add_parser("install", help="install an app")
    ainstall.add_argument("app_id")
    ainstall.set_defaults(func=cmd_apps_install)
    aremove = appssub.add_parser("remove", help="remove an app")
    aremove.add_argument("app_id")
    aremove.set_defaults(func=cmd_apps_remove)

    schedule = sub.add_parser("schedule", help="scheduled automations (systemd timers)")
    ssub = schedule.add_subparsers(dest="subcmd", required=True)
    sadd = ssub.add_parser("add", help="add an automation")
    sadd.add_argument("name", help="short name (letters/digits/-/_)")
    sadd.add_argument("--at", required=True, help='e.g. "daily 08:00", "hourly", "mon 09:00"')
    sadd.add_argument("--prompt", required=True, help="the prompt to run on schedule")
    sadd.set_defaults(func=cmd_schedule_add)
    ssub.add_parser("list", help="list automations").set_defaults(func=cmd_schedule_list)
    srm = ssub.add_parser("remove", help="remove an automation")
    srm.add_argument("name")
    srm.set_defaults(func=cmd_schedule_remove)

    audit = sub.add_parser("audit", help="show recent tool activity")
    audit.add_argument("-n", type=int, default=50, help="number of events (default 50)")
    audit.set_defaults(func=cmd_audit)

    notify = sub.add_parser("notify", help="send a notification")
    notify.add_argument("title", nargs="+", help="notification title")
    notify.add_argument("--body", help="notification body")
    notify.add_argument("--level", default="info",
                        choices=["info", "success", "warning", "error"])
    notify.set_defaults(func=cmd_notify)

    notifs = sub.add_parser("notifications", help="list notifications")
    notifs.add_argument("-n", type=int, default=50, help="number to show")
    notifs.add_argument("--unread", action="store_true", help="only unread")
    notifs.add_argument("--read", action="store_true", help="mark all read")
    notifs.add_argument("--clear", action="store_true", help="delete all")
    notifs.set_defaults(func=cmd_notifications)

    history = sub.add_parser("history", help="print a session's transcript")
    history.add_argument("session", help="session id")
    history.set_defaults(func=cmd_history)

    grant = sub.add_parser("grant", help="always allow a tool in a session")
    grant.add_argument("session", help="session id")
    grant.add_argument("tool", help="tool name (e.g. write_file)")
    grant.set_defaults(func=cmd_grant, revoke=False)

    revoke = sub.add_parser("revoke", help="stop auto-allowing a tool in a session")
    revoke.add_argument("session", help="session id")
    revoke.add_argument("tool", help="tool name")
    revoke.set_defaults(func=cmd_grant, revoke=True)

    index = sub.add_parser("index", help="index files/folders into semantic memory")
    index.add_argument("paths", nargs="*", help="files or folders to index")
    index.add_argument("--stats", action="store_true", help="show what is indexed")
    index.set_defaults(func=cmd_index)

    search = sub.add_parser("search", help="semantic search over indexed files")
    search.add_argument("query", nargs="+", help="the search query")
    search.add_argument("-k", type=int, default=5, help="number of results (default 5)")
    search.set_defaults(func=cmd_search)

    args = parser.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
