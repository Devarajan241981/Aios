#!/usr/bin/env bash
# aios-shell — the AIOS desktop shell: a fullscreen kiosk browser pointed at the
# local web UI served by aiosd. Waits for the daemon to be healthy first.
set -euo pipefail

PORT="${AIOS_PORT:-8765}"
URL="${AIOS_URL:-http://127.0.0.1:${PORT}/}"
HEALTH="${URL%/}/health"

echo "aios-shell: waiting for aiosd at ${HEALTH} ..."
for _ in $(seq 1 100); do
  if curl -fsS "$HEALTH" >/dev/null 2>&1; then
    break
  fi
  sleep 0.2
done

# Launch the first available kiosk-capable browser (Wayland-native preferred).
if command -v firefox >/dev/null 2>&1; then
  exec firefox --kiosk "$URL"
elif command -v chromium >/dev/null 2>&1; then
  exec chromium --kiosk --app="$URL" --ozone-platform=wayland
elif command -v chromium-browser >/dev/null 2>&1; then
  exec chromium-browser --kiosk --app="$URL" --ozone-platform=wayland
elif command -v epiphany >/dev/null 2>&1; then
  exec epiphany -a "$URL"
elif command -v cage >/dev/null 2>&1 && command -v surf >/dev/null 2>&1; then
  exec cage -- surf "$URL"
else
  echo "aios-shell: no kiosk browser found." >&2
  echo "Install one of: firefox, chromium, epiphany, or cage+surf." >&2
  exit 1
fi
